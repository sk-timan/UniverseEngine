# 白名单策略：默认忽略全部，仅提交红框内对象

# --- 仓库根目录 ---
/*
!/.gitignore
!/.cursor/
!/docs/
!/openspec/
!/cmake/
!/Tools/
!/OpenSpecTest/
!/build_win.bat
!/CMakeLists.txt
!/CMakeSettings.json
!/CMakePresets.json
!/open_vs_cmake.bat

# 允许白名单目录下的全部内容
!/.cursor/**
!/docs/**
!/openspec/**
!/cmake/**
!/Tools/**

# --- OpenSpecTest 子项目 ---
/OpenSpecTest/*
!/OpenSpecTest/data/
!/OpenSpecTest/Content/
!/OpenSpecTest/Shader/
!/OpenSpecTest/src/
!/OpenSpecTest/thirdparty/
!/OpenSpecTest/CMakeLists.txt
!/OpenSpecTest/OpenSpecTest.cpp
!/OpenSpecTest/OpenSpecTest.h

!/OpenSpecTest/data/**
!/OpenSpecTest/Content/**
!/OpenSpecTest/Shader/**
!/OpenSpecTest/src/**
!/OpenSpecTest/thirdparty/**

# thirdparty 预编译产物：仅提交链接所需的小文件与 Release 运行时
/OpenSpecTest/thirdparty/**/bin/Debug/
/OpenSpecTest/thirdparty/**/*.pdb
/OpenSpecTest/thirdparty/**/*.exp
/OpenSpecTest/thirdparty/**/lib/Debug/*
!/OpenSpecTest/thirdparty/**/lib/Debug/libclang.lib
/OpenSpecTest/thirdparty/**/lib/Release/*
!/OpenSpecTest/thirdparty/**/lib/Release/libclang.lib
/OpenSpecTest/thirdparty/**/bin/Release/*
!/OpenSpecTest/thirdparty/**/bin/Release/libclang.dll
